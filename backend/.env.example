# ─────────────────────────────────────────────
# SERVEUR
# ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=False
ENV=development

# ─────────────────────────────────────────────
# BASE DE DONNEES MONGODB
# ─────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=quote_keeper

# ─────────────────────────────────────────────
# AUTHENTIFICATION JWT
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────
SECRET_KEY=remplacer_par_une_cle_aleatoire_64_hex
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─────────────────────────────────────────────
# COMPTE DEMO (optionnel — utilisé si MongoDB est absent)
# ─────────────────────────────────────────────
DEMO_EMAIL=demo@test.com
DEMO_PASSWORD=demo123

# ─────────────────────────────────────────────
# API EXTERNE — CITATIONS (API Ninjas)
# Inscription : https://api-ninjas.com → "My Account" → copier la clé
# ─────────────────────────────────────────────
NINJAS_API_KEY=remplacer_par_votre_cle_api_ninjas

# ─────────────────────────────────────────────
# API EXTERNE — IA (Groq / Llama 3)
# Inscription : https://console.groq.com → "API Keys" → créer une clé
# ─────────────────────────────────────────────
GROQ_API_KEY=remplacer_par_votre_cle_groq

# ─────────────────────────────────────────────
# GOOGLE OAUTH 2.0
# Voir README.md section "Obtention des clés API" pour les étapes détaillées
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=remplacer_par_votre_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=remplacer_par_votre_client_secret
GOOGLE_REDIRECT_URI=https://localhost:8000/api/auth/google/callback
GOOGLE_REDIRECT_URI_MOBILE=http://localhost:8001/api/auth/google/callback
FRONTEND_URL=https://localhost:5500

# ─────────────────────────────────────────────
# CORS (origines autorisées, séparées par virgule)
# Ajouter l'IP LAN du PC si vous utilisez l'app mobile sur un vrai téléphone
# Exemple : https://localhost:5500,http://192.168.1.42:8081
# ─────────────────────────────────────────────
CORS_ORIGINS=https://localhost:5500,https://127.0.0.1:5500,http://localhost:8001,http://localhost:8081

# ─────────────────────────────────────────────
# SMTP — ENVOI D'EMAILS OTP
# Laisser vide pour désactiver (mode debug : code affiché dans la console)
# Pour Gmail : activer la validation en 2 étapes, puis créer un "Mot de passe
# d'application" sur https://myaccount.google.com/apppasswords
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=votre.email@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
